@host = https://localhost:5200
@todoId = 6a618049c643fa885ce0f275
@reminderId = 6a618057c643fa885ce0f276


##################################################
# TODOS API
##################################################

##################################################
# GET
##################################################

### Get all todos
GET {{host}}/api/todos
Accept: application/json

###

### Get active todos
GET {{host}}/api/todos?filter=Active
Accept: application/json

###

### Get completed todos
GET {{host}}/api/todos?filter=Completed
Accept: application/json

###

### Get todo by id
GET {{host}}/api/todos/{{todoId}}
Accept: application/json

###

### Get todo by id - Not Found
GET {{host}}/api/todos/aaaaaaaaaaaaaaaaaaaaaaaa
Accept: application/json

###

### Get todos - Invalid filter
GET {{host}}/api/todos?filter=Done
Accept: application/json

##################################################
# CREATE
##################################################

### Create todo
POST {{host}}/api/todos
Content-Type: application/json

{
    "title": "Test Reminder Flow",
    "dueAt": "2026-07-22T10:00:00Z"
}

###

### Create todo - Validation failed
POST {{host}}/api/todos
Content-Type: application/json

{
    "title": ""
}

##################################################
# UPDATE
##################################################

### Update todo
PUT {{host}}/api/todos/{{todoId}}
Content-Type: application/json

{
    "title": "Learn Carter - Updated",
    "isCompleted": false
}

###

### Update todo - Not Found
PUT {{host}}/api/todos/6a59d85063199650d685767d
Content-Type: application/json

{
    "title": "Test",
    "isCompleted": false
}

###

### Update todo - Validation failed
PUT {{host}}/api/todos/{{todoId}}
Content-Type: application/json

{
    "title": "",
    "isCompleted": false
}

##################################################
# TOGGLE
##################################################

### Toggle todo
PATCH {{host}}/api/todos/{{todoId}}/toggle
Accept: application/json

###

### Toggle todo - Not Found
PATCH {{host}}/api/todos/6a59d85063199650d685767d/toggle
Accept: application/json

##################################################
# DELETE
##################################################

### Delete todo
DELETE {{host}}/api/todos/{{todoId}}

###

### Delete todo - Not Found
DELETE {{host}}/api/todos/6a59d85063199650d685767d

##################################################
# CLEAR COMPLETED
##################################################

### Clear completed todos
DELETE {{host}}/api/todos/completed

##################################################
# TOGGLE ALL
##################################################
PATCH {{host}}/api/todos/toggle-all
Content-Type: application/json

{
    "IsCompleted": true
}

### 
PATCH {{host}}/api/todos/toggle-all
Content-Type: application/json

{
    "IsCompleted": false
}

##################################################
# REMINDER FLOW
##################################################

### 1. Create todo for reminder flow
POST {{host}}/api/todos
Content-Type: application/json

{
    "title": "Test Reminder Flow",
    "dueAt": "2026-07-22T10:00:00Z"
}

###

### 2. Get created todo
GET {{host}}/api/todos/{{todoId}}
Accept: application/json

###

### 3. Wait 30 seconds for ReminderScanner
### Then get pending reminders
GET {{host}}/api/reminders?state=Pending
Accept: application/json

###

### 4. Snooze reminder for 1 minute
PATCH {{host}}/api/reminders/{{reminderId}}/snooze
Content-Type: application/json

{
    "minutes": 1
}

###

### 5. Verify snoozed reminder
GET {{host}}/api/reminders?state=Snoozed
Accept: application/json

###

### 6. Wait 1 minute + 30 seconds
### Then verify reactivated reminder
GET {{host}}/api/reminders?state=Pending
Accept: application/json

###

### 7. Dismiss reminder
PATCH {{host}}/api/reminders/{{reminderId}}/dismiss
Accept: application/json

###

### 8. Verify dismissed reminder
GET {{host}}/api/reminders?state=Dismissed
Accept: application/json